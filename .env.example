# Telegram
TELEGRAM_TOKEN=your_bot_token_here

# Anchors (add one block per corridor anchor)
ANCHOR_VIBRANT_DOMAIN=vibrant.stellar.org
ANCHOR_COWRIE_DOMAIN=cowrie.finance

# Database
DB_URL=postgresql+asyncpg://user:pass@localhost:5432/pesachat

# Redis
REDIS_URL=redis://localhost:6379/0

# KMS key for envelope encryption of user keypairs
KMS_KEY_ID=

# Stellar network: testnet | public
STELLAR_NETWORK=testnet
